@startuml HTTP_Layer
title HTTP Layer
skinparam classAttributeIconSize 0

class HttpRequest {
  + method : String
  + target : String
  + version : String
  + headers : String
  + bodyInfo : String
  + remoteAddr : String
}

class HttpResponse {
  + status : int
  + reason : String
  + headers : String
  + body : String
}

class HttpParser {
  - maxHeaderBytes : int
  - maxHeaderCount : int
  + feed(data:String) : String
  + done() : bool
  + request() : HttpRequest
  + reset() : void
}

class ResponseWriter {
  - chunked : bool
  + writeHeaders(res:HttpResponse) : void
  + writeBody(data:String) : void
  + writeChunk(data:String) : void
  + end() : void
}

interface IHandler {
  + handle(req:HttpRequest, res:HttpResponse) : String
}

abstract class AbstractHandler {
  + handle(req:HttpRequest, res:HttpResponse) : String
  # prepare(req:HttpRequest) : int
  # produce(req:HttpRequest, res:HttpResponse) : int
}

class StaticFileHandler
class UploadHandler
class DeleteHandler
class CgiHandler

class Router {
  + route(req:HttpRequest) : IHandler
}

class HandlerFactory {
  + create(req:HttpRequest, vs:VirtualServer, loc:Location) : IHandler
}

class VirtualServer
class Location

class MimeTypes  { 
	+ get(ext:String) : String 
	+ loadFromFile(path:String) : bool 
}

class HttpDate   { 
	+ now() : String 
}
class UrlCodec   { 
	+ percentDecode(s:String) : String 
}
class QueryString { 
	+ parse(qs:String) : String 
}
class ErrorMapper { 
	+ errnoToHttp(e:int) : int 
}

IHandler <|.. AbstractHandler
AbstractHandler <|-- StaticFileHandler
AbstractHandler <|-- UploadHandler
AbstractHandler <|-- DeleteHandler
AbstractHandler <|-- CgiHandler

HttpParser --> HttpRequest
ResponseWriter --> HttpResponse

Router ..> HandlerFactory : creates
Router ..> IHandler : selects
StaticFileHandler ..> MimeTypes : content-type
StaticFileHandler ..> UrlCodec   : path decode
ResponseWriter ..> HttpDate      : Date
Router ..> ErrorMapper           : error map
UploadHandler ..> QueryString    : form parsing
CgiHandler ..> UrlCodec          : query/path

note right of HttpParser
Enforce CRLF, reject both
Content-Length and chunked.
Cap header bytes and count.
end note

note right of ResponseWriter
Set Date, Server, and
Content-Length when known.
Use chunked when unknown.
end note

@enduml
