@startuml
title Core Layer
skinparam classAttributeIconSize 0

class Listener {
  - fd : int
  - address : String
  - port : int
  + open() : bool
  + close() : void
}

class EventLoop {
  - running : bool
  - poller : Poller
  - timers : TimerWheel
  - conns : ConnectionManager
  + run() : void
  + stop() : void
  + registerFd(fd:int, events:int) : void
  + modifyFd(fd:int, events:int) : void
  + unregisterFd(fd:int) : void
}

class Poller {
  + add(fd:int, events:int) : void
  + mod(fd:int, events:int) : void
  + del(fd:int) : void
  + wait(timeoutMs:int) : int
}

class TimerWheel {
  + add(deadlineMs:long, label:String) : int
  + cancel(id:int) : void
  + tick(nowMs:long) : void
}

class ConnectionManager {
  + add(fd:int) : void
  + remove(fd:int) : void
  + find(fd:int) : Connection
  + forEachActive() : void
}

class Connection {
  - state : String
  - readBuf : Buffer
  - writeBuf : Buffer
  - headerDeadlineMs : long
  - bodyDeadlineMs : long
  - writeDeadlineMs : long
  - idleDeadlineMs : long
  - keepAlive : bool
  + onReadable() : void
  + onWritable() : void
  + scheduleDeadlines(nowMs:long) : void
  + close() : void
}

class Buffer {
  - data : String
  - highMark : int
  - lowMark : int
  + append(data:String) : void
  + consume(n:int) : void
  + size() : int
  + aboveHigh() : bool
  + belowLow() : bool
}

class UniqueFd {
  - fd : int
  + get() : int
  + reset(newfd:int) : void
  + release() : int
  - finalize() : void
}

class TimeUtil {
  + nowMs() : long
  + monotonicMs() : long
}

EventLoop *-- Poller
EventLoop *-- TimerWheel
EventLoop *-- ConnectionManager
ConnectionManager *-- Connection
Connection --> Buffer
Connection ..> UniqueFd
TimerWheel ..> Connection
EventLoop ..> TimeUtil
Listener ..> UniqueFd
EventLoop ..> Listener

note right of Connection
States example:
READ_HEADERS, READ_BODY,
DISPATCH, WRITE_HEADERS,
WRITE_BODY, IDLE, CLOSE
end note

@enduml
