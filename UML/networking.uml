@startuml
skinparam packageStyle rectangle
title Overall Architecture with Networking Layer

package "Networking" {
  class EventLoop {
    - fd_set read_fds
    - fd_set write_fds
    - int max_fd
    + void addFD(int fd, int events)
    + void removeFD(int fd)
    + void run()
    + void handleEvents()
  }

  class ConnectionManager {
    - map<int, ClientConnection*> connections
    + void addConnection(int fd)
    + void removeConnection(int fd)
    + ClientConnection* get(int fd)
    + void tick()
  }

  class ClientConnection {
	 + enum State { READ_HEADERS, WRITE, CLOSE }
    - int fd
    - buffer inBuffer
    - buffer outBuffer
    + void onReadable()
    + void onWritable()
    + void close()
	+ void changeState(State newState)
    + void processIncoming()
  }
}

package "Config" {
  class ServerConfig
  class VirtualServer
  class Location
}

package "HTTP" {
  class HttpRequest
  class HttpResponse
  class Headers
  class CookieJar
}

package "Core" {
  class ServerPipeline
  class SessionManager
  class RateLimiter
  class Logger
}

package "Routing" {
  class Router
}

package "Networking" {
  class Server {
    - EventLoop loop
    + void start()
    + void stop()
  }
  class EventLoop {
    + void addFD(int fd, int events)
    + void removeFD(int fd)
    + void run()
    + void handleEvents()
  }
  class ClientConnection
}

Server --> EventLoop
EventLoop --> ClientConnection
ClientConnection --> ServerPipelin

' Relationships
EventLoop --> ConnectionManager
ConnectionManager --> ClientConnection
ClientConnection --> HttpRequest
ClientConnection --> HttpResponse
ClientConnection --> ServerPipeline

ServerPipeline --> SessionManager
ServerPipeline --> RateLimiter
ServerPipeline --> Logger
ServerPipeline --> Router
HttpRequest *-- Headers
HttpRequest *-- CookieJar

@enduml